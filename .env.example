# ============================================
# TES Property System - Demo Environment Setup
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Start MySQL and fill in your DB credentials below
# 3. Run: npm run db:schema  (creates TESdb tables)
# 4. Run: npm run db:seed    (inserts demo data)
# 5. Run: npm run dev        (starts backend + frontend)
#
# Frontend runs on: http://localhost:5173
# Backend API runs on: http://localhost:3000/api
# ============================================

PORT=3000
CORS_ORIGIN=http://localhost:5173

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=TESdb

# JWT
JWT_SECRET=replace_with_a_minimum_32_character_random_secret
JWT_EXPIRES_IN=30d

# App environment
NODE_ENV=development

# Frontend (Vite)
VITE_API_URL=http://localhost:3000/api

# Phone verification (Vonage)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=TESProperty
MOCK_SMS=true

# Demo mode: allow multiple customer accounts to share one phone for OTP verification.
# Set to false in production.
ALLOW_SHARED_VERIFICATION_PHONE=false

# Optional: when your SMS trial can only send to one verified recipient,
# force all OTP messages to this number (example: +639123456789).
VERIFICATION_SMS_OVERRIDE_TO=
